{
  "expo": {
    "name": "TCG Safe",
    "slug": "tcg-safe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "tcgsafe",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tcgsafe.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Para escanear cartas TCG",
        "NSPhotoLibraryUsageDescription": "Para subir fotos de cartas",
        "NSLocationWhenInUseUsageDescription": "Para sugerir zonas seguras cercanas"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "package": "com.tcgsafe.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Para sugerir zonas seguras cercanas"
        }
      ]
    ]
  }
}
